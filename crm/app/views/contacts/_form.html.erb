<%= form_with model: @contact do |f| %>
  <div class="form-group">
    <%= f.label :first_name %>
    <%= f.text_field :first_name, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :last_name %>
    <%= f.text_field :last_name, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :email %>
    <%= f.email_field :email, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :phone %>
    <%= f.telephone_field :phone %>
  </div>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>
  <div class="form-group">
    <%= f.label :account_id %>
    <%= f.collection_select :account_id, Account.order(:name), :id, :name, { include_blank: "—" } %>
  </div>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", @contact.persisted? ? @contact : contacts_path, class: "btn btn-secondary" %>
<% end %>
