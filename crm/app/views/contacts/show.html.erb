<h1><%= @contact.full_name %></h1>
<div class="card">
  <p><strong>Email:</strong> <%= @contact.email %></p>
  <p><strong>Phone:</strong> <%= @contact.phone || "-" %></p>
  <p><strong>Title:</strong> <%= @contact.title || "-" %></p>
  <p><strong>Account:</strong> <%= @contact.account ? link_to(@contact.account.name, @contact.account) : "-" %></p>
  <p>
    <%= link_to "Edit", edit_contact_path(@contact), class: "btn btn-primary" %>
    <%= link_to "New Activity", new_activity_path(activityable_type: "Contact", activityable_id: @contact.id), class: "btn btn-secondary" %>
    <%= button_to "Delete", @contact, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
  </p>
</div>
