<%= form_with model: @deal do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :value %>
    <%= f.number_field :value, step: 0.01, min: 0 %>
  </div>
  <div class="form-group">
    <%= f.label :stage %>
    <%= f.select :stage, Deal.stages.keys.map { |k| [k.titleize, k] } %>
  </div>
  <div class="form-group">
    <%= f.label :expected_close_date %>
    <%= f.date_field :expected_close_date %>
  </div>
  <div class="form-group">
    <%= f.label :account_id %>
    <%= f.collection_select :account_id, Account.order(:name), :id, :name, { include_blank: "—" } %>
  </div>
  <div class="form-group">
    <%= f.label :contact_id %>
    <%= f.collection_select :contact_id, Contact.order(:last_name), :id, :full_name, { include_blank: "—" } %>
  </div>
  <div class="form-group">
    <%= f.label :notes %>
    <%= f.text_area :notes, rows: 3 %>
  </div>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", @deal.persisted? ? @deal : deals_path, class: "btn btn-secondary" %>
<% end %>
