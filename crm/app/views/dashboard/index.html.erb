<h1>Dashboard</h1>
<div class="stats">
  <div class="stat"><span><%= @accounts_count %></span> Accounts</div>
  <div class="stat"><span><%= @contacts_count %></span> Contacts</div>
  <div class="stat"><span><%= @deals_count %></span> Deals</div>
  <div class="stat"><span><%= @leads_count %></span> Leads</div>
  <div class="stat"><span><%= number_to_currency(@deals_value) %></span> Pipeline Value</div>
</div>
<div class="card">
  <h3>Quick Links</h3>
  <p>
    <%= link_to "New Contact", new_contact_path, class: "btn btn-primary" %>
    <%= link_to "New Deal", new_deal_path, class: "btn btn-primary" %>
    <%= link_to "New Lead", new_lead_path, class: "btn btn-primary" %>
  </p>
</div>
