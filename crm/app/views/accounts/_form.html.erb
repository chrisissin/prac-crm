<%= form_with model: @account do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, required: true %>
  </div>
  <div class="form-group">
    <%= f.label :industry %>
    <%= f.text_field :industry %>
  </div>
  <div class="form-group">
    <%= f.label :email %>
    <%= f.email_field :email %>
  </div>
  <div class="form-group">
    <%= f.label :phone %>
    <%= f.telephone_field :phone %>
  </div>
  <div class="form-group">
    <%= f.label :address %>
    <%= f.text_area :address, rows: 3 %>
  </div>
  <div class="form-group">
    <%= f.label :status %>
    <%= f.select :status, Account.statuses.keys.map { |k| [k.titleize, k] } %>
  </div>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", @account.persisted? ? @account : accounts_path, class: "btn btn-secondary" %>
<% end %>
